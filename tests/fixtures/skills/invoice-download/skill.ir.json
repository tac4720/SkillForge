{
  "name": "invoice-download",
  "version": "0.1.0",
  "actor": "fixture",
  "inputsSchema": {
    "invoice_month": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "email": {
      "type": "string"
    },
    "password": {
      "type": "string"
    }
  },
  "permissions": {
    "browser": {
      "domains": {
        "allow": [
          "http://127.0.0.1"
        ]
      }
    }
  },
  "steps": [
    {
      "id": "step-login",
      "type": "browser.navigate",
      "with": {
        "url": "http://127.0.0.1/login"
      }
    },
    {
      "id": "step-download",
      "type": "browser.download",
      "target": {
        "locatorCandidates": [
          "role=button[name=\"Download PDF\"]"
        ]
      },
      "with": {
        "saveAs": "/tmp/invoice.pdf"
      }
    }
  ],
  "assertions": [
    {
      "type": "fileExists",
      "path": "/tmp/invoice.pdf"
    }
  ]
}
